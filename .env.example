# ── Qwen / Alibaba Cloud Model Studio (DashScope) ────────────────────────────
# Create a key in the Model Studio console. When absent, the app auto-falls back
# to the deterministic offline Fake embedder + narrator, so dev + CI need NO key.
DASHSCOPE_API_KEY=
# Production Qwen-heavy routes fail closed when only fake clients are available.
# Set true only for an explicitly offline, non-qualifying demo environment;
# /ready still reports fake/no-key providers as unavailable.
ALLOW_FAKE_QWEN=false

# OpenAI-compatible base URL. Default is the hackathon international endpoint.
# China (Beijing) alternative: https://dashscope.aliyuncs.com/compatible-mode/v1
# Workspace-scoped form also works: https://<WorkspaceId>.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Shared live-request resilience bounds (code clamps timeout to 1-120s and
# retries to 0-5 even if these values are misconfigured).
QWEN_TIMEOUT_MS=20000
QWEN_MAX_RETRIES=2

# Qwen chat model used by the narrator (RAG answer over recalled memories).
QWEN_MODEL=qwen-plus

# Production recall re-ranks the hybrid candidate pool with this Qwen model.
# A timeout falls back to the incoming hybrid order instead of failing recall.
QWEN_RERANK_MODEL=qwen-plus
RERANK_TIMEOUT_MS=3000
SEMANTIC_JUDGE_TIMEOUT_MS=8000
SEMANTIC_EMBED_TIMEOUT_MS=10000

# Qwen text-embedding model + dimension. text-embedding-v4 defaults to 1024,
# which matches the vector(1024) memory column. Keep the two in lockstep.
QWEN_EMBED_MODEL=text-embedding-v4
EMBED_DIM=1024

# ── Memory store: pgvector-compatible PostgreSQL ─────────────────────────────
# Local dev / CI: a stock pgvector/pgvector docker image.
# Production: Alibaba Cloud AnalyticDB for PostgreSQL or ApsaraDB RDS for
# PostgreSQL (pgvector extension) — same pg-wire protocol, same SQL.
# Replace this value before starting Compose. It initializes the local database;
# no default credential is embedded in the Compose manifest.
POSTGRES_PASSWORD=
POSTGRES_USER=memoryagent
POSTGRES_DB=memoryagent
# Host-side npm scripts/tests (when using docker-compose.dev.yml). Construct both
# URLs with the random password above; blank values fail closed.
DATABASE_URL=
# Backend container connection string uses Docker-internal hostname `db`.
COMPOSE_DATABASE_URL=
PGPOOL_MAX=5

# ── HTTP server ──────────────────────────────────────────────────────────────
# Function Compute custom-container default CAPort is 9000.
PORT=9000
# Aggregate JSON request cap. The 10 MiB default fits one maximum-size vision
# data URL while bounding parser memory; code accepts only 1-20 MiB.
MAX_JSON_BODY_BYTES=10485760
# Coarse per-client cap over the complete HTTP surface (fixed one-minute window).
# Qwen-backed routes also retain their durable daily per-subject/global quotas.
HTTP_RATE_LIMIT_MAX=300

# ── Judge authentication + tenant isolation ─────────────────────────────────
# Production requires a judge key by default and fails closed when it is absent.
# The matching credential determines the tenant; request bodies/headers cannot
# choose a different tenant. Production requires at least 32 characters; use
# 32 random bytes (for example: `openssl rand -hex 32`).
JUDGE_API_KEY=
JUDGE_TENANT_ID=_public
# Multi-tenant alternative (takes precedence when set):
# JUDGE_API_KEYS_JSON={"judge-a":"replace-with-32-plus-random-characters-a","judge-b":"replace-with-32-plus-random-characters-b"}
JUDGE_AUTH_REQUIRED=true
PUBLIC_TENANT_ID=_public

# Remote Streamable HTTP MCP is always authenticated/fail-closed. When omitted,
# it reuses JUDGE_API_KEY/JUDGE_TENANT_ID. Stdio remains local/trusted.
# MCP_API_KEY=replace-with-a-separate-long-random-key
# MCP_TENANT_ID=_public
MCP_MAX_BODY_BYTES=262144
MCP_DAILY_LIMIT=500
MCP_DAILY_LIMIT_GLOBAL=2000

# Same-origin UI works with an empty list. Add exact origins only for a separate
# trusted dashboard; arbitrary origins are never reflected.
CORS_ORIGIN=

# The Compose production topology binds the backend to loopback behind exactly
# one host reverse-proxy hop. Prefer exact proxy CIDRs in other topologies; set
# TRUST_PROXY_HOPS empty only when clients connect directly with no proxy.
TRUST_PROXY_ADDRESSES=
TRUST_PROXY_HOPS=1

# ── Qwen-spend quotas ────────────────────────────────────────────────────────
# Every Qwen-heavy surface has per-subject and global UTC-daily request ceilings.
# One accepted HTTP/MCP request consumes one unit, independent of model fan-out.
# Production uses the shared PostgreSQL quota table when DATABASE_URL is set, so
# limits remain atomic across replicas and restarts. Tests/local injected stores
# use the in-memory backend; another durable backend can also be injected.
INGEST_DAILY_LIMIT=100
INGEST_DAILY_LIMIT_GLOBAL=500
RECALL_DAILY_LIMIT=200
RECALL_DAILY_LIMIT_GLOBAL=2000
SEMANTIC_AUDIT_DAILY_LIMIT=20
SEMANTIC_AUDIT_DAILY_LIMIT_GLOBAL=100

# ── Validation anomaly policy (operational heuristics, not legal rules) ─────
EMPLOYER_COST_NET_RATIO_MIN=1.25
EMPLOYER_COST_NET_RATIO_MAX=1.45
PAYMENT_GRACE_DAYS=7

# ── Function Compute private PostgreSQL network (deploy/deploy-fc.sh) ────────
# All three resources must be in REGION and able to reach the managed database.
FC_VPC_ID=vpc-replace-me
FC_VSWITCH_ID=vsw-replace-me
FC_SECURITY_GROUP_ID=sg-replace-me
