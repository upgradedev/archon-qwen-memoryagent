# ── Qwen / Alibaba Cloud Model Studio (DashScope) ────────────────────────────
# Create a key in the Model Studio console. When absent, the app auto-falls back
# to the deterministic offline Fake embedder + narrator, so dev + CI need NO key.
DASHSCOPE_API_KEY=
# Production Qwen-heavy routes fail closed when only fake clients are available.
# Set true only for an explicitly offline, non-qualifying demo environment;
# /ready still reports fake/no-key providers as unavailable.
ALLOW_FAKE_QWEN=false

# OpenAI-compatible base URL. The default is the international shared endpoint.
# Production accepts only official pay-as-you-go Alibaba Model Studio surfaces:
# the documented shared DashScope hosts, or a DNS-valid workspace-dedicated
# https://llm-<workspace>.<supported-region>.maas.aliyuncs.com/compatible-mode/v1
# URL. HTTPS, the exact path, and a credential/query/fragment-free URL are
# enforced in both runtime and deploy preflight; trial/token/coding plans and
# arbitrary compatible proxies are rejected. Official region/host reference:
# https://www.alibabacloud.com/help/en/model-studio/base-url
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Shared live-request resilience bounds (code clamps timeout to 1-120s and
# retries to 0-5 even if these values are misconfigured).
QWEN_TIMEOUT_MS=20000
QWEN_MAX_RETRIES=2
# Atomic memory writes use a bounded embedding worker pool (clamped 1-8).
EMBEDDING_CONCURRENCY=4

# Qwen chat model used by the narrator (RAG answer over recalled memories).
QWEN_MODEL=qwen-plus

# Semantic-contradiction judge only. Promote a dated candidate here only after
# the clean same-commit A/B gate passes; this does not change narration/rerank.
QWEN_JUDGE_MODEL=qwen-plus

# Production recall re-ranks the hybrid candidate pool with this Qwen model.
# A timeout falls back to the incoming hybrid order instead of failing recall.
QWEN_RERANK_MODEL=qwen-plus
RERANK_TIMEOUT_MS=3000
SEMANTIC_JUDGE_TIMEOUT_MS=8000
SEMANTIC_EMBED_TIMEOUT_MS=10000

# Qwen text-embedding model + dimension. text-embedding-v4 defaults to 1024,
# which matches the vector(1024) memory column. Keep the two in lockstep.
QWEN_EMBED_MODEL=text-embedding-v4
EMBED_DIM=1024

# ── Memory store: pgvector-compatible PostgreSQL ─────────────────────────────
# Local dev / CI: a stock pgvector/pgvector docker image.
# Production: Alibaba Cloud AnalyticDB for PostgreSQL or ApsaraDB RDS for
# PostgreSQL (pgvector extension) — same pg-wire protocol, same SQL.
# Bootstrap/admin credentials exist only in PostgreSQL and the one-shot db-init
# job. The backend must never receive either value. Use different 32+ character,
# URL-safe random passwords for POSTGRES_PASSWORD and MEMORY_APP_DB_PASSWORD.
POSTGRES_PASSWORD=
POSTGRES_USER=memoryagent_admin
POSTGRES_DB=memoryagent
# One-shot schema/grant job only (Docker-internal hostname `db`).
MIGRATION_DATABASE_URL=
MEMORY_APP_DB_PASSWORD=
# Host-side scripts/tests authenticate only as the fixed DML-only role
# `memoryagent_app` (when using docker-compose.dev.yml).
DATABASE_URL=
# Long-lived backend runtime DSN; use memoryagent_app and hostname `db`.
COMPOSE_DATABASE_URL=
# Mandatory for production redeploy (commented only so isolated local dev can
# start without the other project). For a shared cluster set the neighbouring
# database name only; for separate servers also set host/port. Verification must produce
# ACL denial (same cluster) or authentication denial (separate server).
# CROSS_APP_DATABASE_NAME=autopilot
# CROSS_APP_DATABASE_HOST=autopilot-db
# CROSS_APP_DATABASE_PORT=5432
PGPOOL_MAX=5

# ── HTTP server ──────────────────────────────────────────────────────────────
# Function Compute custom-container default CAPort is 9000.
PORT=9000
# Aggregate JSON request cap. The 10 MiB default fits one maximum-size vision
# data URL while bounding parser memory; code accepts only 1-20 MiB.
MAX_JSON_BODY_BYTES=10485760
# Coarse per-client cap over the complete HTTP surface (fixed one-minute window).
# Qwen-backed routes also retain their durable daily per-subject/global quotas.
HTTP_RATE_LIMIT_MAX=300

# ── Judge authentication + tenant isolation ─────────────────────────────────
# Production requires a judge key by default and fails closed when it is absent.
# The matching credential determines the tenant; request bodies/headers cannot
# choose a different tenant. Production requires at least 32 characters; use
# 32 random bytes (for example: `openssl rand -hex 32`).
JUDGE_API_KEY=
JUDGE_TENANT_ID=_judge_demo
# Multi-tenant alternative (takes precedence when set):
# JUDGE_API_KEYS_JSON={"judge-a":"replace-with-32-plus-random-characters-a","judge-b":"replace-with-32-plus-random-characters-b"}
JUDGE_AUTH_REQUIRED=true
PUBLIC_TENANT_ID=_public
# Unsafe migration-only escape hatch. Leave false: a shared judge/public tenant
# exposes authenticated writes through unauthenticated public reads.
ALLOW_SHARED_PUBLIC_JUDGE_TENANT=false

# Remote Streamable HTTP MCP is always authenticated/fail-closed. When omitted,
# it reuses JUDGE_API_KEY/JUDGE_TENANT_ID. Stdio remains local/trusted, but its
# provider calls still use durable PostgreSQL quotas + process admission. Real-
# Qwen stdio requires DATABASE_URL; production also requires the explicit opt-in.
# MCP_API_KEY=replace-with-a-separate-long-random-key
# MCP_TENANT_ID=_judge_demo
MCP_STDIO_TENANT_ID=_judge_demo
MCP_STDIO_ENABLED=false
MCP_STDIO_MAX_RESULT_BYTES=262144
# Loopback by default. Set 0.0.0.0 explicitly only behind an authenticated TLS edge.
MCP_HTTP_HOST=127.0.0.1
MCP_MAX_BODY_BYTES=262144
MCP_DAILY_LIMIT=500
MCP_DAILY_LIMIT_GLOBAL=2000

# Same-origin UI works with an empty list. Add exact origins only for a separate
# trusted dashboard; arbitrary origins are never reflected.
CORS_ORIGIN=

# Disabled by default. Configure either 1-16 exact proxy IP/CIDR entries or a
# bounded hop count—not both. The documented loopback Compose deployment may set
# TRUST_PROXY_HOPS=1 in its private .env because it has exactly one proxy hop.
TRUST_PROXY_ADDRESSES=
TRUST_PROXY_HOPS=

# ── Qwen-spend quotas ────────────────────────────────────────────────────────
# Every Qwen-heavy surface has per-subject and global UTC-daily work-unit pools.
# Units are preflight policy weights, not provider billing/call attempts. Recall
# reserves four worst-case logical model operations (embedding, rerank, narration,
# bounded repair); HTTP document batches reserve five fixed units per document;
# MCP single-fact ingest reserves one. Transport retries do not add logical units.
# Production uses the shared PostgreSQL quota table when DATABASE_URL is set, so
# limits remain atomic across replicas and restarts. Tests/local injected stores
# use the in-memory backend; another durable backend can also be injected.
# A cache-miss owner for /ready/deep reserves three units (embedding, narration,
# bounded citation repair). Cache hits and same-process in-flight followers cost 0.
DEEP_READINESS_DAILY_LIMIT=30
DEEP_READINESS_DAILY_LIMIT_GLOBAL=300
INGEST_DAILY_LIMIT=100
INGEST_DAILY_LIMIT_GLOBAL=500
INGEST_DAILY_LIMIT_JUDGE_RESERVE=200
RECALL_DAILY_LIMIT=200
RECALL_DAILY_LIMIT_GLOBAL=2000
RECALL_DAILY_LIMIT_JUDGE_RESERVE=400
# Semantic work units: one per reserved Qwen judge pair (default audit reserves 25).
SEMANTIC_AUDIT_DAILY_LIMIT=500
SEMANTIC_AUDIT_DAILY_LIMIT_GLOBAL=2500
SEMANTIC_AUDIT_DAILY_LIMIT_JUDGE_RESERVE=2500
EXTRACTION_CONCURRENCY=3
QWEN_PUBLIC_CONCURRENCY=2
QWEN_JUDGE_CONCURRENCY=2
LIFECYCLE_CANDIDATE_CAP=5000

# ── Validation anomaly policy (operational heuristics, not legal rules) ─────
EMPLOYER_COST_NET_RATIO_MIN=1.25
EMPLOYER_COST_NET_RATIO_MAX=1.45
PAYMENT_GRACE_DAYS=7

# ── Function Compute private PostgreSQL network (deploy/deploy-fc.sh) ────────
# All three resources must be in REGION and able to reach the managed database.
FC_VPC_ID=vpc-replace-me
FC_VSWITCH_ID=vsw-replace-me
FC_SECURITY_GROUP_ID=sg-replace-me
